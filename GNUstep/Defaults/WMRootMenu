(
  "Void Linux",
  (
    Applications,
    OPEN_PLMENU,
    "|| wmmenugen -parser:xdg /usr/share/applications/"
  ),
  (Run..., EXEC, "%A(Run,Type command to run)"),
  (
    "Window Maker",
    ("Info Panel ...", INFO_PANEL),
    ("Legal Panel ...", LEGAL_PANEL),
    (Preferences, EXEC, WPrefs),
    ("Refresh screen", REFRESH),
    (Restart, RESTART)
  ),
  (
    WorkSpace,
    (Appearance, OPEN_MENU, appearance.menu),
    ("Arrange Icons", ARRANGE_ICONS),
    ("Clear Session", CLEAR_SESSION),
    ("Hide Others", HIDE_OTHERS),
    ("Save Session", SAVE_SESSION),
    ("Show All", SHOW_ALL),
    (Workspaces, WORKSPACE_MENU)
  ),
  (
    Shortcuts,
    ("Play/Pause", SHORTCUT, XF86AudioPlay, EXEC, "controls.sh play_pause"),
    ("Next Song", SHORTCUT, XF86AudioNext, EXEC, "controls.sh next_track"),
    (
      "Previous Song",
      SHORTCUT,
      XF86AudioPrev,
      EXEC,
      "controls.sh prev_track"
    ),
    (
      "Volume Up",
      SHORTCUT,
      XF86AudioRaiseVolume,
      EXEC,
      "controls.sh volume_up"
    ),
    (
      "Volume Down",
      SHORTCUT,
      XF86AudioLowerVolume,
      EXEC,
      "controls.sh volume_down"
    ),
    (
      "Brightness Up",
      SHORTCUT,
      XF86MonBrightnessUp,
      EXEC,
      "controls.sh brightness_up"
    ),
    (
      "Brightness Down",
      SHORTCUT,
      XF86MonBrightnessDown,
      EXEC,
      "controls.sh brightness_down"
    ),
    (Mute, SHORTCUT, XF86AudioMute, EXEC, "controls.sh volume_mute"),
    (Rofi, SHORTCUT, "Mod4+r", EXEC, "rofi -show drun"),
    ("Change Wallpaper", SHORTCUT, "Mod4+w", EXEC, wallpaper.sh),
    ("File Browser", SHORTCUT, "Mod4+f", EXEC, "rofi -show filebrowser"),
    ("Window Switch", SHORTCUT, "Mod4+Tab", EXEC, "rofi -show window"),
    (
      "Lock Screen",
      SHORTCUT,
      "Mod4+l",
      EXEC,
      "betterlockscreen -l blur"
    ),
    (Screenshot, SHORTCUT, "Mod4+Print", EXEC, scrot),
    (Terminal, SHORTCUT, "Mod4+Return", EXEC, kitty)
  ),
  (Suspend, EXEC, "systemctl suspend"),
  (Exit, EXIT),
  ("Exit session", SHUTDOWN)
)
